APP_ENV=local
NIMIQ_NETWORK=testnet
NIMIQ_RPC_URL=https://rpc.testnet.nimiqwatch.com
PODS_TREASURY_ADDRESS=
DATABASE_URL=postgresql://pods:pods-local-only@127.0.0.1:54329/pods
PORT=3412

# Railway Buckets use false for both settings. Local MinIO uses true.
PODS_S3_ENDPOINT=http://127.0.0.1:59000
PODS_S3_REGION=us-east-1
PODS_S3_BUCKET=pods-evidence
PODS_S3_ACCESS_KEY_ID=pods-local
PODS_S3_SECRET_ACCESS_KEY=pods-local-password
PODS_S3_FORCE_PATH_STYLE=true
PODS_S3_CREATE_BUCKET_IF_MISSING=true

# Alpha capability lock. Closed and off are the safe deployment defaults.
PODS_ALPHA_ACCESS=closed
PODS_PROFILES_ENABLED=false
PODS_POD_CHAT_ENABLED=false
PODS_SOCIAL_GRAPH_ENABLED=false
PODS_DMS_ENABLED=false
PODS_DM_REQUESTS_ENABLED=false
PODS_UPLOADS_ENABLED=false
PODS_GIF_ENABLED=false
PODS_MODERATION_ENABLED=false
PODS_RATE_LIMITS_ENABLED=false
PODS_RATE_LIMIT_HMAC_SECRET=replace-with-at-least-16-random-characters
PODS_PUBLIC_VISITOR_ROOMS_ENABLED=false
PODS_REVIEW_EXCEPTIONS_ENABLED=false
PODS_SETTLEMENT_ENABLED=false
PODS_ALPHA_REFUND_ENABLED=false
PODS_DEPOSIT_MODE=off
REALTIME_TRANSPORT=poll

PODS_OPS_ACCESS_TOKEN=
PODS_OPS_SESSION_SECRET=
PODS_OPS_REVIEWER_ID=pods-team-reviewer
PODS_TREASURY_PRIVATE_KEY_HEX=
PODS_DEPOSIT_POLL_INTERVAL_MS=5000
PODS_PREFLIGHT_RECIPIENT=
