{
  "name": "@pods/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node --import tsx --input-type=module --eval \"await import('./src/index.ts')\"",
    "dev": "node --watch --import tsx src/index.ts",
    "start": "node --import tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clock:advance": "node --import tsx src/clock/command.ts",
    "preflight:generate": "node --import tsx src/preflight/generate-treasury.ts",
    "preflight:rpc": "node --import tsx src/preflight/check-rpc.ts",
    "preflight:send": "node --import tsx src/preflight/send-transfer.ts",
    "preflight:reconcile": "node --import tsx src/preflight/reconcile-transfer.ts"
  },
  "dependencies": {
    "@nimiq/core": "2.7.1",
    "@pods/db": "workspace:*",
    "@pods/domain": "workspace:*"
  },
  "devDependencies": {
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
